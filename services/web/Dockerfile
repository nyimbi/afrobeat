# syntax=docker/dockerfile:1.7
# ── Stage 1: deps ─────────────────────────────────────────────────────────────
FROM node:20-alpine AS deps

WORKDIR /app

# Copy manifests only — layer cached until package*.json changes.
COPY services/web/package.json services/web/package-lock.json ./

# --frozen-lockfile ensures reproducible installs; fails fast on drift.
RUN npm ci --frozen-lockfile

# ── Stage 2: builder ──────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY services/web/ ./

# Build-time env vars that must be baked into the static bundle.
# Values are placeholders; override at build time with --build-arg if needed.
# Runtime secrets must NOT be included here — they belong in ENV at runtime.
ARG NEXT_PUBLIC_API_URL=http://localhost:8000
ARG NEXT_PUBLIC_R2_PUBLIC_URL=""
ARG NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
ARG NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=""

ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL \
	NEXT_PUBLIC_R2_PUBLIC_URL=$NEXT_PUBLIC_R2_PUBLIC_URL \
	NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=$NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY \
	NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=$NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY \
	NEXT_TELEMETRY_DISABLED=1 \
	NODE_ENV=production

# output: standalone in next.config.js produces a self-contained server bundle.
RUN npm run build

# ── Stage 3: runner ───────────────────────────────────────────────────────────
FROM node:20-alpine AS runner

WORKDIR /app

# Least-privilege user (nextjs is convention from Next.js docs).
RUN addgroup -g 1001 -S nodejs && adduser -S nextjs -u 1001 -G nodejs

ENV NODE_ENV=production \
	NEXT_TELEMETRY_DISABLED=1 \
	PORT=3000

# standalone output includes its own node_modules subset — copy the minimum set.
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
COPY --from=builder --chown=nextjs:nodejs /app/public ./public

USER nextjs

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
	CMD wget -qO- http://localhost:3000/api/health 2>/dev/null || exit 1

# standalone server entrypoint generated by Next.js at build time.
CMD ["node", "server.js"]
